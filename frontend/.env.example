# ===========================================
# GEC Event Portal Frontend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# API URL - Your backend server URL
# Local development:
VITE_API_URL=http://localhost:5000/api

# Production (replace with your Render backend URL):
# VITE_API_URL=https://your-backend-name.onrender.com/api

# ===========================================
# Email Domain Restriction
# ===========================================
# Only allow emails from this domain (must match backend)
# Set to * to allow all domains
VITE_ALLOWED_EMAIL_DOMAIN=gec.ac.in

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
