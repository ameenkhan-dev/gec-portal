# ===========================================
# GEC Event Portal - Environment Configuration
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:3000

# ===========================================
# Database Type Selection
# ===========================================
# Options: 'mysql' or 'postgres'
# If not set, auto-detects:
#   - DATABASE_URL present → PostgreSQL
#   - Otherwise → MySQL (default for local dev)
DB_TYPE=mysql

# ===========================================
# MySQL Configuration (Local Development)
# ===========================================
# Used when DB_TYPE=mysql or auto-detected as MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=gec_event_portal
DB_POOL_SIZE=10

# ===========================================
# PostgreSQL Configuration (Production/Render)
# ===========================================
# Option 1: Use DATABASE_URL (recommended for Render)
# If DATABASE_URL is set, it takes precedence over individual vars
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Option 2: Use individual environment variables
# DB_TYPE=postgres
# DB_HOST=your-postgres-host.render.com
# DB_PORT=5432
# DB_USER=postgres_user
# DB_PASSWORD=your_secure_password
# DB_NAME=gec_event_portal
# DB_SSL=true

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# File Upload Configuration
# ===========================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ===========================================
# Email Domain Restriction
# ===========================================
# Only allow emails from this domain (e.g., gec.ac.in)
# Set to * to allow all domains
ALLOWED_EMAIL_DOMAIN=gec.ac.in

# ===========================================
# Email Configuration (Optional - for notifications)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=noreply@gecportal.com
